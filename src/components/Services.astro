---
import { services } from '../data/services';
---

<section id="uslugi" class="container mt-space">
  <div class="section-header border-box mb-space">
    <h2>NASZA SPECJALIZACJA</h2>
  </div>

  <div class="grid-3">
    {
      services.map((service) => (
        <article class="service-item border-box">
          <div class="img-wrapper border-bottom">
            <img
              src={service.image}
              alt={service.alt}
              loading="lazy"
              decoding="async"
              width="600"
              height="375"
            />
          </div>
          <div class="content-padding">
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </div>
        </article>
      ))
    }
  </div>
</section>
