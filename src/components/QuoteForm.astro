---
const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.chlopakioddzwieku.com';
---

<section id="wycena" class="container border-box mt-space" aria-labelledby="wycena-heading">
  <div class="section-header border-bottom">
    <h2 id="wycena-heading">DARMOWA WYCENA</h2>
  </div>
  <div class="content-padding">
    <form
      id="quote-form"
      class="quote-form"
      method="post"
      action="https://formsubmit.co/chlopakioddzwieku@gmail.com"
      novalidate
    >
      <div class="form-grid">
        <input type="hidden" name="_subject" value="Wycena — Chłopaki od dźwięku" />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_captcha" value="true" />
        <input
          type="hidden"
          name="_next"
          id="q-next"
          value={`${site}/#wycena-sent`}
        />
        <input
          type="text"
          name="_honey"
          tabindex="-1"
          autocomplete="off"
          class="sr-only"
          aria-hidden="true"
        />

        <input type="hidden" name="_replyto" id="q-replyto" value="" />

        <div class="field">
          <label for="q-name">Imię i nazwisko</label>
          <input
            id="q-name"
            name="name"
            type="text"
            autocomplete="name"
            maxlength="120"
            placeholder="Np. Jan Kowalski"
            aria-describedby="q-name-error"
          />
          <p class="field-error" id="q-name-error" role="alert"></p>
        </div>
        <div class="field">
          <label for="q-phone">Telefon</label>
          <input
            id="q-phone"
            name="phone"
            type="tel"
            inputmode="tel"
            autocomplete="tel"
            maxlength="20"
            placeholder="Np. +48 600 000 000"
            aria-describedby="q-phone-error"
          />
          <p class="field-error" id="q-phone-error" role="alert"></p>
        </div>
        <div class="field">
          <label for="q-email">Email</label>
          <input
            id="q-email"
            name="email"
            type="email"
            autocomplete="email"
            maxlength="254"
            placeholder="Np. jan.kowalski@example.com"
            aria-describedby="q-email-error"
          />
          <p class="field-error" id="q-email-error" role="alert"></p>
        </div>
        <div class="field field-full">
          <label for="q-msg">Co i kiedy organizujesz?</label>
          <textarea
            id="q-msg"
            name="message"
            rows="5"
            placeholder="Np. koncert / konferencja, miasto, data, liczba osób, co potrzebujesz (dźwięk/światło/multimedia)"
            aria-describedby="q-msg-error"
          ></textarea>
          <p class="field-error" id="q-msg-error" role="alert"></p>
        </div>
        <div class="field field-full checkbox-row">
          <label class="checkbox">
            <input
              id="q-consent"
              name="consent"
              type="checkbox"
              aria-describedby="q-consent-error"
            />
            <span>Wyrażam zgodę na kontakt w sprawie wyceny.</span>
          </label>
          <p class="field-error" id="q-consent-error" role="alert"></p>
        </div>
        <div class="field field-full">
          <button class="btn-solid" type="submit">WYŚLIJ</button>
          <p class="form-hint" id="quote-status" role="status" aria-live="polite"></p>
          <noscript>
            <p class="form-hint">
              Masz wyłączony JavaScript — napisz do nas na
              <a href="mailto:chlopakioddzwieku@gmail.com">chlopakioddzwieku@gmail.com</a>.
            </p>
          </noscript>
        </div>
      </div>
    </form>
  </div>
</section>
