<a href="/" class="logo" title="Strona główna">
  <picture class="logo__picture logo__picture--light">
    <source srcset="/logo-chod.webp" type="image/webp" />
    <img
      class="logo__img"
      src="/logo-chod.png"
      alt="Chłopaki od dźwięku"
      width="320"
      height="175"
      decoding="async"
      fetchpriority="high"
    />
  </picture>
  <picture class="logo__picture logo__picture--dark">
    <source srcset="/logo-chod-dark.webp" type="image/webp" />
    <img
      class="logo__img"
      src="/logo-chod-dark.png"
      alt=""
      width="320"
      height="175"
      decoding="async"
      aria-hidden="true"
    />
  </picture>
  <span class="sr-only">Chłopaki od dźwięku — strona główna</span>
</a>
